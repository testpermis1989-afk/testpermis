{
  "name": "permis-maroc",
  "version": "1.0.0",
  "private": true,
  "description": "Test du Permis de Conduire Maroc - اختبار رخصة القيادة بالمغرب",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:local": "cross-env STORAGE_MODE=local DATABASE_URL=file:./data/permis.db next dev -p 3000",
    "build": "next build && node scripts/copy-build.js",
    "build:electron": "cross-env NEXT_PUBLIC_STORAGE_MODE=local next build && node scripts/copy-build.js",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "start:local": "cross-env STORAGE_MODE=local LOCAL_DATA_DIR=./data DATABASE_URL=file:./data/permis.db NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint .",
    "electron": "cross-env STORAGE_MODE=local DATABASE_URL=file:./data/permis.db electron .",
    "electron:dev": "cross-env STORAGE_MODE=local DATABASE_URL=file:./data/permis.db electron . --dev",
    "electron:build": "cross-env NEXT_PUBLIC_STORAGE_MODE=local next build && node scripts/copy-build.js && electron-builder --win --x64",
    "electron:build:portable": "cross-env NEXT_PUBLIC_STORAGE_MODE=local next build && node scripts/copy-build.js && electron-builder --win portable --x64",
    "db:push": "prisma db push",
    "db:push:local": "cross-env DATABASE_URL=file:./data/permis.db prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@mdxeditor/editor": "^3.39.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@reactuses/core": "^6.0.5",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.82.0",
    "@tanstack/react-table": "^8.21.3",
    "adm-zip": "^0.5.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.23.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next": "16.1.3",
    "next-auth": "^4.24.11",
    "next-intl": "^4.3.4",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^2.15.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.6",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "unrar": "^0.2.0",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "z-ai-web-dev-sdk": "^0.0.17",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "build": {
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.wasm",
      "**/node_modules/sql.js/**",
      "**/node_modules/sharp/**"
    ],
    "compression": "maximum",
    "appId": "com.permis.maroc",
    "productName": "Permis Maroc",
    "copyright": "Copyright © 2025 Permis Maroc",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**",
      "app-server/**",
      "!node_modules/**",
      "!app-server/skills/**",
      "!app-server/upload/**",
      "!app-server/examples/**",
      "!app-server/.prisma/**",
      "!app-server/**/*.zip",
      "!app-server/**/README.md",
      "!app-server/**/LICENSE",
      "!app-server/**/CHANGELOG*",
      "!app-server/**/.eslint*",
      "!app-server/**/tsconfig*",
      "!app-server/**/*.map",
      "!app-server/**/src/**",
      "!app-server/node_modules/typescript/**",
      "!app-server/node_modules/@img/sharp-libvips-linux*/**",
      "!app-server/node_modules/@img/sharp-linux*/**",
      "!app-server/node_modules/source-map/**",
      "!app-server/node_modules/source-map-support/**",
      "!app-server/node_modules/@prisma/engines/**",
      "!app-server/node_modules/.prisma/**",
      "!app-server/node_modules/prisma/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Permis Maroc",
      "artifactName": "PermisMaroc-Setup.exe",
      "uninstallDisplayName": "Permis Maroc",
      "language": 1036
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "bun-types": "^1.3.4",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
